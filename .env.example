# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is used ONLY in server code (API routes / server actions). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Google Drive OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must exactly match an Authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ---- Token encryption ----
# 32-byte key, base64 encoded. Generate: openssl rand -base64 32
DRIVE_TOKEN_ENC_KEY=replace-with-openssl-rand-base64-32

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
NEXT_PUBLIC_POS_WEBHOOK_SECRET=DNHOUSE_SECRET_123
